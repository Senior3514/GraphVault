# GraphVault MCP server configuration.
# Copy to `.env` and fill in, or set these in your MCP client config.
# Configuration is read from environment variables ONLY — no secrets are
# hardcoded and neither the token nor the device id is ever logged.
#
# Read tools (list/read/search/backlinks/graph/stats) work with just the URL,
# token, and a vault. The conflict-safe WRITE tools (create/update/append/
# delete) are enabled only when GRAPHVAULT_DEVICE_ID is also set.

# Base URL of your self-hosted GraphVault server.
GRAPHVAULT_SERVER_URL=https://vault.example.com

# Bearer token issued by your GraphVault server (keep this secret).
GRAPHVAULT_TOKEN=replace-with-your-token

# The vault to expose. Provide EITHER the id...
GRAPHVAULT_VAULT_ID=your-vault-id
# ...OR resolve it by name via GET /v1/vaults (comment out the id above):
# GRAPHVAULT_VAULT_NAME=Personal

# Device id bound to GRAPHVAULT_TOKEN. REQUIRED to enable the write tools; the
# server's push endpoint rejects a deviceId that does not match the token's
# device. Leave unset for a strictly read-only deployment (the write tools are
# then not registered and report "writes disabled" if invoked). Never logged.
# GRAPHVAULT_DEVICE_ID=your-device-id

# Optional: index cache TTL in milliseconds (default 30000 = 30s). After this
# the vault is reloaded on the next tool call so agents see recent edits.
# GRAPHVAULT_INDEX_TTL_MS=30000
