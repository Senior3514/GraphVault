{
  "name": "@graphvault/mcp",
  "version": "0.1.0",
  "description": "Standalone stdio MCP (Model Context Protocol) server exposing a self-hosted GraphVault vault to Claude Desktop and other MCP-compatible agents - read/search/graph tools, note resources, and prompt templates.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Senior3514/GraphVault.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/Senior3514/GraphVault/blob/main/packages/mcp/README.md",
  "bugs": "https://github.com/Senior3514/GraphVault/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "graphvault",
    "markdown",
    "notes",
    "knowledge-graph"
  ],
  "type": "module",
  "bin": {
    "graphvault-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@graphvault/engine": "workspace:*",
    "@graphvault/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
