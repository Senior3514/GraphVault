{
  "name": "@graphvault/cli",
  "version": "0.1.0",
  "description": "Command-line access to a local GraphVault vault: list, search, stats, graph export, and a read-only local HTTP API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Senior3514/GraphVault.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Senior3514/GraphVault/blob/main/packages/cli/README.md",
  "bugs": "https://github.com/Senior3514/GraphVault/issues",
  "keywords": [
    "graphvault",
    "cli",
    "markdown",
    "notes",
    "knowledge-graph"
  ],
  "type": "module",
  "bin": {
    "graphvault": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@graphvault/engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
