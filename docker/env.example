# GraphVault docker-compose environment.
#
# Copy to `.env` (which docker compose reads automatically) and edit before
# `docker compose up`. The `.env` file is gitignored — keep secrets out of VCS.
#
#   cp docker/env.example .env
#
# For the full production (TLS) stack run:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# See docs/deployment.md for a 5-minute VPS walkthrough.

# --- PostgreSQL credentials (used by both the `db` and `server` services) ---
POSTGRES_USER=graphvault
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=graphvault

# --- Server configuration ---------------------------------------------------
# Comma-separated allowed CORS origins, or * to allow any (dev only). In
# production set this to your web client's origin, e.g. https://notes.example.com
GRAPHVAULT_CORS_ORIGIN=*

# Max blob upload size in bytes (default 64 MiB).
GRAPHVAULT_MAX_BLOB_BYTES=67108864

# Optional at-rest blob encryption. A base64-encoded 32-byte AES-256-GCM key.
# Leave empty to store blob bytes as plaintext on disk.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WARNING: Losing this key makes ALL encrypted blobs unrecoverable — back it up
# securely (password manager, offline copy). If unset a process-lifetime key is
# used for WebDAV/S3/AI credentials, meaning those creds are lost on restart.
GRAPHVAULT_ENCRYPTION_KEY=

# --- Production / TLS (required when using docker-compose.prod.yml) ----------
# Public hostname for the server, e.g. notes.example.com (no https:// prefix).
# A DNS A record must point this name at the host before Caddy can obtain a cert.
DOMAIN=notes.example.com

# Let's Encrypt registration e-mail. Caddy sends renewal failure notices here.
ACME_EMAIL=you@example.com
