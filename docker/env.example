# GraphVault docker-compose environment.
#
# Copy to `.env` (which docker compose reads automatically) and edit before
# `docker compose up`. The `.env` file is gitignored — keep secrets out of VCS.
#
#   cp docker/env.example .env

# --- PostgreSQL credentials (used by both the `db` and `server` services) ---
POSTGRES_USER=graphvault
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=graphvault

# --- Server configuration ---------------------------------------------------
# Comma-separated allowed CORS origins. In production set this to your web
# client's exact origin, e.g. https://notes.example.com. The startup preflight
# REFUSES to boot in production if this is '*'.
GRAPHVAULT_CORS_ORIGIN=https://notes.example.com

# Reverse-proxy / transport. A TLS-terminating proxy (Caddy/nginx) fronts the
# server. Keep both of these true in production: TRUST_PROXY so client IPs and
# X-Forwarded-Proto are read correctly, REQUIRE_HTTPS so plaintext is rejected.
# The preflight refuses to boot in production with REQUIRE_HTTPS=false.
GRAPHVAULT_TRUST_PROXY=true
GRAPHVAULT_REQUIRE_HTTPS=true

# Rate limiting: a per-client global cap plus a stricter cap on /v1/auth/*.
GRAPHVAULT_RATE_LIMIT_MAX=300
GRAPHVAULT_RATE_LIMIT_WINDOW=60000
GRAPHVAULT_AUTH_RATE_LIMIT_MAX=10

# Max blob upload size in bytes (default 64 MiB).
GRAPHVAULT_MAX_BLOB_BYTES=67108864

# Optional at-rest blob encryption. A base64-encoded 32-byte key. Leave empty to
# store blob bytes as plaintext on disk (the preflight warns). Generate one with:
#   openssl rand -base64 32
# Losing this key makes encrypted blobs unrecoverable — back it up separately.
GRAPHVAULT_ENCRYPTION_KEY=
