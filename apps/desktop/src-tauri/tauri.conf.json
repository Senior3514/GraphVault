{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "GraphVault",
  "version": "0.1.0",
  "identifier": "ai.graphvault.desktop",

  "build": {
    "beforeDevCommand": "pnpm --filter @graphvault/web dev",
    "devUrl": "http://localhost:3000",

    "beforeBuildCommand": "pnpm -w run build:web",
    "frontendDist": "../../apps/web/out"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GraphVault",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' http://localhost:* ws://localhost:*",
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": false,
      "pattern": {
        "use": "brownfield"
      }
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },

  "plugins": {
    "fs": {
      "scope": {
        "allow": [],
        "deny": []
      },
      "requireLiteralLeadingDot": true
    }
  }
}
