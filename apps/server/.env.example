# GraphVault server configuration. Copy to `.env` and adjust.

# Network
GRAPHVAULT_HOST=127.0.0.1
GRAPHVAULT_PORT=4000

# Comma-separated allowed origins, or * in development.
GRAPHVAULT_CORS_ORIGIN=*

# Where blobs and the database are stored on disk.
GRAPHVAULT_DATA_DIR=./storage

NODE_ENV=development
