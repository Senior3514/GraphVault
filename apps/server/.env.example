# GraphVault server configuration. Copy to `.env` and adjust.

# Network
GRAPHVAULT_HOST=127.0.0.1
GRAPHVAULT_PORT=4000

# Comma-separated allowed origins, or * in development. In PRODUCTION this MUST
# be an explicit allowlist of your web origins (e.g. https://notes.example.com);
# the startup preflight refuses to boot with '*' when NODE_ENV=production.
GRAPHVAULT_CORS_ORIGIN=*

# Where blobs and the database are stored on disk.
GRAPHVAULT_DATA_DIR=./storage

# Storage backend: "memory" (default, dev/test, non-durable) or "postgres".
GRAPHVAULT_STORAGE=memory

# PostgreSQL connection string. Required only when GRAPHVAULT_STORAGE=postgres
# (the preflight refuses to boot postgres mode in production without it).
# Also read by Prisma (prisma generate / migrate).
# DATABASE_URL=postgresql://graphvault:graphvault@localhost:5432/graphvault

# Max blob upload size in bytes (default 64 MiB). The blob PUT and the WebDAV/S3
# vault-upload proxies use this cap.
GRAPHVAULT_MAX_BLOB_BYTES=67108864

# Max body size in bytes for JSON / non-blob routes (default 1 MiB). Much smaller
# than the blob cap so a giant JSON payload to auth/push can't exhaust memory.
GRAPHVAULT_MAX_JSON_BYTES=1048576

# --- Connection hardening (safe defaults; tune only if you have a reason) ---
# Slowloris / slow-client defense and idle-socket bounds. Times are in ms.
# REQUEST_TIMEOUT: max time to fully receive a request before aborting it.
# KEEP_ALIVE_TIMEOUT: idle keep-alive socket lifetime; keep it ABOVE your proxy's
#   upstream keep-alive (nginx default 60s) to avoid 502s from a race.
# CONNECTION_TIMEOUT: max time a socket may stay open without completing headers.
# MAX_PARAM_LENGTH: max length of a single URL path parameter (e.g. :hash).
GRAPHVAULT_REQUEST_TIMEOUT_MS=30000
GRAPHVAULT_KEEP_ALIVE_TIMEOUT_MS=72000
GRAPHVAULT_CONNECTION_TIMEOUT_MS=60000
GRAPHVAULT_MAX_PARAM_LENGTH=256

# --- Security (Milestone 8) — see docs/security-basics.md for the fuller model.

# Rate limiting. A global per-client cap, plus a stricter cap on /v1/auth/*
# routes to slow credential stuffing / brute force.
GRAPHVAULT_RATE_LIMIT_MAX=300
GRAPHVAULT_RATE_LIMIT_WINDOW=60000
GRAPHVAULT_AUTH_RATE_LIMIT_MAX=10

# Reverse-proxy / transport model. A TLS-terminating proxy (Caddy/nginx) fronts
# the server in production. Set GRAPHVAULT_TRUST_PROXY=true so the server reads
# X-Forwarded-For / X-Forwarded-Proto for correct client IPs and HTTPS detection
# — configure nginx to pass `proxy_set_header X-Forwarded-Proto $scheme;`.
# GRAPHVAULT_REQUIRE_HTTPS rejects plaintext (defaults to on when
# NODE_ENV=production; the preflight refuses to boot production with it off).
# Leave both off for local http dev.
# GRAPHVAULT_TRUST_PROXY=true
# GRAPHVAULT_REQUIRE_HTTPS=true

# Optional at-rest blob encryption. When set, blob bytes are encrypted on disk
# with AES-256-GCM (the content hash stays the hash of the PLAINTEXT, so dedupe
# and the wire protocol are unchanged). Must be a base64-encoded 32-byte key;
# a malformed key makes the server fail fast on startup. In production the
# preflight WARNS when this is unset. Generate one with:
#   openssl rand -base64 32
# Keep this key secret and backed up: losing it makes encrypted blobs
# unrecoverable. Unset = blobs stored as plaintext (legacy behavior).
# GRAPHVAULT_ENCRYPTION_KEY=

NODE_ENV=development

# --- WebDAV proxy (M18) ---
# WebDAV credentials are stored per-user, encrypted at rest in the storage backend.
# Encryption uses GRAPHVAULT_ENCRYPTION_KEY (above) when set; otherwise a process-
# lifetime random key is used (credentials are lost on server restart if no key is set).
# The client NEVER receives WebDAV credentials — all WebDAV traffic is proxied here.
# No additional env config is required; users configure their WebDAV URL + creds via
# Settings (POST /v1/storage/webdav/config) after signing in.

# --- Azure Blob Storage proxy (Wave 16) ---
# Store a GraphVault vault (graphvault-vault.json) in Azure Blob Storage without
# the browser ever holding the account key. Credentials (account, container,
# accountKey) are stored per-user, encrypted at rest with GRAPHVAULT_ENCRYPTION_KEY
# above (or a process-lifetime key if none is set), and are NEVER returned to the
# client. Requests are signed server-side with the Azure Shared Key scheme
# (HMAC-SHA256, x-ms-version 2021-08-06). No env config required — users configure
# their account/container/accountKey via Settings (POST /v1/storage/azure/config).
# An optional endpoint override supports Azurite for local testing.

# --- Google Cloud Storage proxy (Wave 16) ---
# Store a GraphVault vault in GCS via its S3-compatible XML API, signed with AWS
# SigV4 using HMAC interop credentials. Credentials (bucket, accessId, secret,
# optional prefix) are stored per-user, encrypted at rest with GRAPHVAULT_ENCRYPTION_KEY
# above (or a process-lifetime key if none is set), and are NEVER returned to the
# client. Create an HMAC key under Cloud Storage > Settings > Interoperability.
# No env config required — users configure via Settings (POST /v1/storage/gcs/config).

# --- AI proxy / BFF (BYO-key server mode) ---
# Users configure their AI API key (OpenRouter or direct provider) via Settings.
# The key is encrypted at rest using GRAPHVAULT_ENCRYPTION_KEY above (or a process-
# lifetime key if none is set) and is NEVER returned to the client.
# The browser sends only the chat prompt — the key is added server-side.
#
# Per-user/day request cap (0 = unlimited; default 200).
# Set this on your deployment to protect against runaway key usage.
# GRAPHVAULT_AI_DAILY_CAP=200

# --- Public graph-snapshot store (Wave 18) — OPT-IN, off by default ---
# Lets the web client share a READ-ONLY graph via a SHORT url (/embed?id=<id>)
# instead of a giant encoded blob in the URL. The snapshot payload is an OPAQUE,
# already-encoded string (gzip+base64url of a graph JSON) the client produces;
# the server stores and returns it verbatim and NEVER parses or executes it
# beyond size validation. Snapshots are UNAUTHENTICATED public shares: anyone
# with the short id can read it. This is OFF by default — when disabled, every
# /v1/snapshots* route returns 404 and the feature is invisible.
#
# Enable it only if you want to host public read-only graph shares:
# GRAPHVAULT_SNAPSHOTS_ENABLED=false
#
# Abuse-resistance knobs (used only when enabled):
#  - MAX_BYTES: reject snapshots whose encoded payload exceeds this (413).
#  - MAX_COUNT: cap total stored snapshots; oldest are evicted oldest-first.
#  - TTL_DAYS: expire snapshots after this many days (swept on read; 0 = never).
#  - RATE_LIMIT_MAX: stricter per-window cap on POST /v1/snapshots to deter abuse.
# GRAPHVAULT_SNAPSHOT_MAX_BYTES=400000
# GRAPHVAULT_SNAPSHOT_MAX_COUNT=5000
# GRAPHVAULT_SNAPSHOT_TTL_DAYS=30
# GRAPHVAULT_SNAPSHOT_RATE_LIMIT_MAX=20
