# GraphVault server configuration. Copy to `.env` and adjust.

# Network
GRAPHVAULT_HOST=127.0.0.1
GRAPHVAULT_PORT=4000

# Comma-separated allowed origins, or * in development.
GRAPHVAULT_CORS_ORIGIN=*

# Where blobs and the database are stored on disk.
GRAPHVAULT_DATA_DIR=./storage

# Storage backend: "memory" (default, dev/test, non-durable) or "postgres".
GRAPHVAULT_STORAGE=memory

# PostgreSQL connection string. Required only when GRAPHVAULT_STORAGE=postgres.
# Also read by Prisma (prisma generate / migrate).
# DATABASE_URL=postgresql://graphvault:graphvault@localhost:5432/graphvault

# Max blob upload size in bytes (default 64 MiB).
GRAPHVAULT_MAX_BLOB_BYTES=67108864

NODE_ENV=development
