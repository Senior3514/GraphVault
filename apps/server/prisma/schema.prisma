// GraphVault sync server — PostgreSQL schema (spec §3).
//
// This schema is the durable backend selected via GRAPHVAULT_STORAGE=postgres.
// In environments without a live database (and without `prisma generate` run),
// the server defaults to the in-memory backend and never imports the generated
// client, so this file is not required to build the default path.
//
// Generate with:  pnpm --filter @graphvault/server prisma:generate
// Migrate with:   pnpm --filter @graphvault/server prisma:migrate

generator client {
  provider = "prisma-client-js"
  output   = "../src/store/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  devices Device[]
  vaults  Vault[]
  tokens  Token[]

  @@map("users")
}

model Device {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  lastSeen  DateTime @default(now()) @map("last_seen")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokens Token[]

  @@index([userId])
  @@map("devices")
}

// Opaque bearer tokens; only the SHA-256 hash of the token is stored.
model Token {
  tokenHash String   @id @map("token_hash")
  userId    String   @map("user_id")
  deviceId  String   @map("device_id")
  expiresAt BigInt   @map("expires_at") // unix epoch seconds
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tokens")
}

model Vault {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String
  headRevision Int      @default(0) @map("head_revision")
  createdAt    DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  files     File[]
  revisions Revision[]

  @@index([userId])
  @@map("vaults")
}

model File {
  id               String   @id @default(uuid())
  vaultId          String   @map("vault_id")
  path             String
  currentVersionId String?  @unique @map("current_version_id")
  isDeleted        Boolean  @default(false) @map("is_deleted")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  vault          Vault         @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  versions       FileVersion[] @relation("FileVersions")
  currentVersion FileVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id])

  @@unique([vaultId, path])
  @@index([vaultId])
  @@map("files")
}

model FileVersion {
  id        String   @id @default(uuid())
  fileId    String   @map("file_id")
  hash      String? // null for a tombstone
  size      Int
  mtime     BigInt // unix epoch ms
  deleted   Boolean  @default(false)
  revision  Int // per-vault seq this version was recorded at
  createdAt DateTime @default(now()) @map("created_at")

  file       File  @relation("FileVersions", fields: [fileId], references: [id], onDelete: Cascade)
  currentFor File? @relation("CurrentVersion")

  @@index([fileId])
  @@index([revision])
  @@map("file_versions")
}

// One row per accepted change-set step; seq is the per-vault head at that step.
model Revision {
  id        String   @id @default(uuid())
  vaultId   String   @map("vault_id")
  seq       Int
  createdAt DateTime @default(now()) @map("created_at")

  vault Vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, seq])
  @@index([vaultId])
  @@map("revisions")
}

// Content-addressed blob metadata; the bytes live on disk under dataDir.
model Blob {
  hash      String   @id
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blobs")
}

// --- Server-proxied storage / AI credentials (one row per user) ------------
// Secret fields hold an AES-256-GCM ciphertext (base64, `nonce||tag||ciphertext`);
// the raw secret is never stored. Non-secret fields are plaintext (shown in
// Settings). userId is the primary key (one config per provider per user).

model WebDavConfig {
  userId            String   @id @map("user_id")
  url               String
  username          String
  encryptedPassword String   @map("encrypted_password")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("webdav_configs")
}

model S3Config {
  userId                   String   @id @map("user_id")
  endpoint                 String?
  region                   String
  bucket                   String
  accessKeyId              String   @map("access_key_id")
  encryptedSecretAccessKey String   @map("encrypted_secret_access_key")
  prefix                   String?
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("s3_configs")
}

model AzureConfig {
  userId              String   @id @map("user_id")
  account             String
  container           String
  encryptedAccountKey String   @map("encrypted_account_key")
  endpoint            String?
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("azure_configs")
}

model GcsConfig {
  userId          String   @id @map("user_id")
  bucket          String
  accessId        String   @map("access_id")
  encryptedSecret String   @map("encrypted_secret")
  prefix          String?
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("gcs_configs")
}

model AiConfig {
  userId          String   @id @map("user_id")
  encryptedApiKey String   @map("encrypted_api_key")
  gateway         String
  baseUrl         String?  @map("base_url")
  model           String?
  spendCapUsd     Float?   @map("spend_cap_usd")
  dailyRequestCap Int?     @map("daily_request_cap")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("ai_configs")
}

// Durable per-user/day AI spend + request window (replaces the old in-process
// daily counter so caps survive a restart). One row per user; the active window
// is keyed by windowDate. See docs/ai-bff.md §4.
model AiSpendWindow {
  userId     String   @id @map("user_id")
  windowDate String   @map("window_date") // "YYYY-MM-DD" UTC
  requests   Int      @default(0)
  spentUsd   Float    @default(0) @map("spent_usd")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("ai_spend_windows")
}

// --- "Connect anything" inbound webhook (inbox) ----------------------------
// Per-connector tokens (only the SHA-256 hash is stored, like auth Token) and a
// per-user audit log of every inbound attempt.

model InboxToken {
  id         String    @id
  userId     String    @map("user_id")
  vaultId    String    @map("vault_id")
  label      String
  tokenHash  String    @unique @map("token_hash")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@index([userId])
  @@map("inbox_tokens")
}

model InboxAuditEntry {
  id      String   @id
  userId  String   @map("user_id")
  tokenId String   @map("token_id")
  source  String
  path    String?
  bytes   Int
  status  String
  at      DateTime @default(now())

  @@index([userId, at])
  @@map("inbox_audit_entries")
}
