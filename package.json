{
  "name": "graphvault",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first markdown notes with self-hosted sync and a graph you can think in.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @graphvault/shared build && pnpm --filter @graphvault/engine build && pnpm --filter @graphvault/sync-core build && pnpm --filter @graphvault/web build",
    "dev": "pnpm -r --parallel run dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "smoke:web": "node scripts/smoke-web.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "playwright-core": "^1.49.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
